ad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjE0Mzl4OTYwLnNkci5DMyJ9&_nc_ohc=D5LAzvCCK3QQ7kNvwFr7MYV&_nc_oc=Adls9ggu32Ci1vpzJxso5LAnbfH8O3QPYcYbZwj6oKCm-g30xkutfMA-YZicsjOe-QLTuE7ID7gdEyJe7R7TWF0g&_nc_ad=z-m&_nc_cid=1174&_nc_zt=23&_nc_ht=instagram.fnag4-5.fna&_nc_gid=HYse7skY211EQQliH8dQWg&_nc_ss=8&oh=00_AfzHVIDoxYdz_qCUCXdE5N_4oSdXTsLOGumdRILSVVfqmA&oe=69B58D62","height":427,"width":640}]},"carousel_parent_id":"3794707186426099830_52937990183","sharing_friction_info":{"bloks_app_url":null,"should_have_sharing_friction":false},"preview":null,"organic_tracking_token":null,"video_versions":null,"media_overlay_info":null,"usertags":null,"media_type":1,"code":null,"display_uri":null,"user":null,"number_of_qualities":null,"product_type":"carousel_item","taken_at":1766584367,"previous_submitter":null,"link":null,"story_cta":null,"has_liked":null,"like_count":null,"inventory_source":null,"logging_info_token":null}],"location":null,"has_audio":null,"floating_context_items":[],"clips_metadata":null,"clips_attribution_info":null,"ai_interactive_embodiment_attachment_style_info":null,"has_liked":false,"open_carousel_submission_state":"closed","carousel_parent_id":null,"display_uri":null,"preview":null,"accessibility_caption":null,"previous_submitter":null,"link":null,"story_cta":null,"like_count":104,"logging_info_token":null,"carousel_media_count":8,"comment_count":10,"preview_comments":[],"view_count":null,"top_likers":[],"hidden_likes_string_variant":-1,"fb_like_count":31,"crosspost_metadata":{"is_feedback_aggregated":null,"is_feed_feedback_aggregated":true},"social_context":[],"can_reshare":null,"enable_media_notes_production":false,"media_repost_count":null,"saved_collection_ids":null,"has_viewer_saved":null,"sharing_friction_info":{"should_have_sharing_friction":false,"bloks_app_url":null},"caption":{"text":"*\u2728THE UDAAN OF MOTHER'S PRIDE WORLD SCHOOL*\u2728\n\nMother's Pride World School, Chakarbhata, Bilaspur celebrated The Annual Function 2.0 \"Udaan - Prideens' Flight of Success\" (2025-2026) on 20.12.2025. Chairman Mr. Sabino D'Souza, Vice-Chairman Mr. Ramkumar Arya, Principal Ms.Vandana D'Souza , Secretary Mr.Sylvester D'Souza, Joint Secretary Mr. Shyamkumar Arya\nwelcomed Honourable MLA Mr. Dharamlal Kaushik ji as the Chief Guest of the Day. The Guest of Honour of the Day was Ms.Neelam Vijay Verma. Honorable Mr. Kaushik ji appreciated the school\u2019s rapid progress and notable achievements since its establishment. The Honourable MLA also interacted with the students backstage, motivating them to present an energetic and confident performance. He also appreciated the holistic development of the students under the wise guidance of the Chairman, Principal and the entire team members of the School.","pk":"17882748702425110","has_translation":null,"created_at":1766584370},"boosted_status":null,"boost_unavailable_identifier":null,"boost_unavailable_reason":null,"can_see_insights_as_brand":false,"affiliate_info":null,"ig_media_sharing_disabled":false,"share_ids":null,"feed_demotion_control":null,"feed_recs_demotion_control":null,"main_feed_carousel_starting_media_id":null,"owner":{"show_account_transparency_details":true,"id":"52937990183"},"is_shared_from_basel":null,"fb_comment_count":7,"all_previous_submitters":[],"follow_hashtag_info":null,"media_attributions_data":[],"wearable_attribution_info":null,"caption_is_edited":false,"commenting_disabled_for_viewer":null}]}},"extensions":{"is_final":true,"all_video_dash_prefetch_representations":[]}},"sequence_number":0}}]],["CometResourceScheduler","registerHighPriHashes",null,[["SeKgIH9","oN++V4F"]]]]}},{"__bbox":null},{"__bbox":null}]]]}</script>
